{
  "storage": {
    "luks_lvm": {
      "banner": "luks + lvm + ext4. TPM2 unlocking.",
      "pvname": "pvroot",
      "vgname": "luks",
      "partition": {
        "efi": "EFISYS",
        "root": "root",
        "swap": "swap",
        "home": "home"
      },
      "packages": [
        "lvm2",
        "cryptsetup"
      ]
    },
    "plain_lvm": {
      "banner": "For resource constrained machines. lvm + ext4.",
      "vgname": "linux",
      "partition": {
        "efi": "EFISYS",
        "root": "root",
        "swap": "swap",
        "home": "home"
      },
      "packages": [
        "lvm2"
      ]
    }
  },
  "software": {
    "minimal": {
      "banner": "only core packages",
      "target": "multi-user"
    },
    "kde": {
      "banner": "KDE Desktop Environment",
      "target": "graphical"
    }
  },
  "packages": [
    "@core",
    "-nano-default-editor",
    "systemd-boot-unsigned",
    "efibootmgr",
    "chrony",
    "selinux-policy",
    "vim-enhanced",
    "vim-default-editor",
    "vim-ctrlp",
    "jq",
    "glibc-all-langpacks",
    "tmux"
  ]
}
