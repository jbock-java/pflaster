[alias]
  co = checkout
  br = branch --sort=committerdate
  ci = commit
  st = status
[core]
  editor = vim
  pager = less -F -X
[credential]
  helper = cache --timeout=3600
[pull]
  ff = only
[user]
  #name = Full Name
  #email = email@address.com
[merge]
  #tool = meld
[init]
  defaultBranch = main
